    if not m: continue
    name = m.group(1)
    if name not in q1_base: continue
    block = []
    j=i-1
    while j>=0 and lines[j].strip().startswith('//'):
        block.append(lines[j].strip()[2:].strip())
        j-=1
    block = list(reversed(block))
    for b in block:
        for field in fields:
