        i=0
        while i < len(lines):
            m = re.match(r'message\\s+(\\w+)\\s*\\{', lines[i].strip())
            if not m:
                i+=1; continue
            name = m.group(1)
            # collect preceding comment block
            block=[]; j=i-1
            while j>=0 and lines[j].strip().startswith('//'):
                block.append(lines[j].strip()[2:].strip())
                j-=1
            block=list(reversed(block))
            if name in out and '是否实现绑定: 是' in '\\n'.join(block):
                for b in block:
                    if '路由码 route_code' in b:
                        out[name]['route_code']=int(re.search(r'(\\d+)', b).group(1))
                    elif '小版本 schema_rev' in b:
                        out[name]['schema_rev']=int(re.search(r'(\\d+)', b).group(1))
                    elif '标识策略 id_policy' in b:
                        out[name]['id_policy']=parse_value('id_policy', b)
                    elif '回放域 replay_scope' in b:
                        out[name]['replay_scope']=parse_value('replay_scope', b)
                    elif '需要时间戳 stamp_required' in b:
                        out[name]['stamp_required']=parse_value('stamp_required', b)
                    elif '需要序号 ordinal_required' in b:
                        out[name]['ordinal_required']=parse_value('ordinal_required', b)
                    elif '模式位 mode_flag' in b:
                        out[name]['mode_flag']=int(re.search(r'(\\d+)', b).group(1))
                    elif '飞行阶段 phase' in b:
                        out[name]['phase_value']=int(re.search(r'=(\\d+)', b).group(1))
                    elif '载荷分支 branch' in b:
                        out[name]['branch']=parse_value('branch', b)
                    elif '合法区间 band' in b:
                        out[name]['band']=parse_value('band', b)
            i += 1
    return out

