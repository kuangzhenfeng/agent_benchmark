import re, json, sys
from pathlib import Path
root = Path('/home/steven/app/agent_benchmark/archive/20260620-1817-cpp-benchmark-v2/agents/codex-gpt-5-4')
targets = [
'stage_state','stage_states','stage_state_view','stage_state_patch','stage_state_legacy','stage_state_v2',
'thrust_report','thrust_reports','thrust_report_view','thrust_report_patch','thrust_report_legacy','thrust_report_v2',
'nav_solution','nav_solutions','nav_solution_view','nav_solution_patch','nav_solution_legacy','nav_solution_v2',
'sep_event','sep_events','sep_event_view','sep_event_patch','sep_event_legacy','sep_event_v2',
'fts_status','fts_statuses','fts_status_view','fts_status_patch','fts_status_legacy','fts_status_v2',
'payload_frame','payload_frames','payload_frame_view','payload_frame_patch','payload_frame_legacy','payload_frame_v2',
'link_quality','link_qualities','link_quality_view','link_quality_patch','link_quality_legacy','link_quality_v2',
'thermal_sample','thermal_samples','thermal_sample_view','thermal_sample_patch','thermal_sample_legacy','thermal_sample_v2']
fields = ['route_code','schema_rev','id_policy','replay_scope','stamp_required','ordinal_required','mode_flag','phase_value','branch','band_min','band_max']
id_map = {'严格必填':'strict','保留空值':'keep_blank','保留空':'keep_blank','空则生成':'auto_gen'}
replay_map = {'不回放':'none','本级':'stage','本箭':'vehicle','本靶区':'range'}
branch_map = {'遥测':'telemetry','指令':'command','配置':'config','事件':'event'}

def parse_q1_truth():
    q1 = root/'q01-long-context-protocol'
    def pv(field, text):
        text=text.strip()
        if field in ('route_code','schema_rev','mode_flag','phase_value'):
            m=re.search(r'(\\d+)', text)
            return int(m.group(1)) if m else None
        if field in ('stamp_required','ordinal_required'):
            if 'true' in text: return True
            if 'false' in text: return False
            return None
        if field=='id_policy':
            for k,v in id_map.items():
                if k in text: return v
        if field=='replay_scope':
            for k,v in replay_map.items():
                if k in text: return v
        if field=='branch':
            for k,v in branch_map.items():
                if k in text: return v
        if field=='band':
            m=re.search(r'\\[(\\-?\\d+),\\s*(\\-?\\d+)\\]', text)
            return [int(m.group(1)), int(m.group(2))] if m else None
        return None
    text=(q1/'corpus/protocol/v6.proto').read_text().splitlines()
    base={t:{} for t in targets}
    i=0
    meta_fields=['route_code','schema_rev','id_policy','replay_scope','stamp_required','ordinal_required','mode_flag','phase_value','branch','band']
    while i < len(text):
        m=re.match(r'message\\s+(\\w+)\\s*\\{', text[i].strip())
        if not m:
            i+=1; continue
        name=m.group(1)
        depth=text[i].count('{')-text[i].count('}')
        block=[]; i+=1
        while i < len(text) and depth>0:
            depth += text[i].count('{')-text[i].count('}')
            block.append(text[i].rstrip()); i+=1
        if name not in base: continue
        for line in block:
            s=line.strip()
            if not s.startswith('//'): continue
            s=s[2:].strip()
            for f in meta_fields:
                if s.startswith(f+':'):
                    val=pv(f, s.split(':',1)[1])
                    if val is not None:
                        base[name][f]=val
    final=json.loads(json.dumps(base))
    for fname in ['v1-to-v2.md','v2-to-v3.md','v3-to-v4.md','v4-to-v5.md','v5-to-v6.md']:
        txt=(q1/'corpus/changelog'/fname).read_text()
        for struct, field, rhs in re.findall(r'\\*\\*(\\w+)\\.(\\w+)\\*\\*：["'^'"\\n]*?\\*\\*(.*?)\\*\\*', txt):
            if struct in final:
                val=pv(field, rhs)
                if val is not None:
                    final[struct][field]=val
    for path in sorted((q1/'corpus/errata').glob('ERR-*.md')):
        txt=path.read_text()
        for struct, field, rhs in re.findall(r'\\*\\*(\\w+)\\.(\\w+)\\*\\*：原文档记为 .*?应更正为 \\*\\*(.*?)\\*\\*', txt):
            if struct in final:
                val=pv(field, rhs)
                if val is not None:
                    final[struct][field]=val
    return {k:{'route_code':v['route_code'],'schema_rev':v['schema_rev'],'id_policy':v['id_policy'],'replay_scope':v['replay_scope'],'stamp_required':v['stamp_required'],'ordinal_required':v['ordinal_required'],'mode_flag':v['mode_flag'],'phase_value':v['phase_value'],'branch':v['branch'],'band_min':v['band'][0],'band_max':v['band'][1]} for k,v in final.items()}

def parse_q2_truth():
    q2 = root/'q02-protocol-adaptation'
    out={t:{} for t in targets}
    for proto in ['status.proto','action.proto','config.proto','event.proto']:
        lines=(q2/'系统B'/proto).read_text().splitlines()
        for i,line in enumerate(lines):
            m=re.match(r'message\\s+(\\w+)\\s*\\{', line.strip())
            if not m: continue
            name=m.group(1)
            block=[]; j=i-1
            while j>=0 and lines[j].strip().startswith('//'):
                block.append(lines[j].strip()[2:].strip()); j-=1
            block=list(reversed(block))
            if name not in out or '是否实现绑定: 是' not in '\\n'.join(block):
                continue
            for b in block:
                if '路由码 route_code' in b: out[name]['route_code']=int(re.search(r'(\\d+)',b).group(1))
                elif '小版本 schema_rev' in b: out[name]['schema_rev']=int(re.search(r'(\\d+)',b).group(1))
                elif '标识策略 id_policy' in b:
                    for k,v in id_map.items():
                        if k in b: out[name]['id_policy']=v
                elif '回放域 replay_scope' in b:
                    for k,v in replay_map.items():
                        if k in b: out[name]['replay_scope']=v
                elif '需要时间戳 stamp_required' in b: out[name]['stamp_required']='true' in b
                elif '需要序号 ordinal_required' in b: out[name]['ordinal_required']='true' in b
                elif '模式位 mode_flag' in b: out[name]['mode_flag']=int(re.search(r'(\\d+)',b).group(1))
                elif '飞行阶段 phase' in b: out[name]['phase_value']=int(re.search(r'=(\\d+)',b).group(1))
                elif '载荷分支 branch' in b:
                    for k,v in branch_map.items():
                        if k in b: out[name]['branch']=v
                elif '合法区间 band' in b:
                    m2=re.search(r'\\[(\\d+),\\s*(\\d+)\\]',b)
                    out[name]['band_min']=int(m2.group(1)); out[name]['band_max']=int(m2.group(2))
    return out

def parse_source(path):
    txt=path.read_text()
    pat=re.compile(r'\\{Structure::(\\w+),\\s*(\\d+),\\s*(\\d+),\\s*IdPolicy::(\\w+),\\s*ReplayScope::(\\w+),\\s*(true|false),\\s*(true|false),\\s*(\\d+)u,\\s*(\\d+),\\s*Branch::(\\w+),\\s*(-?\\d+),\\s*(-?\\d+)\\}')
    out={}
    for m in pat.finditer(txt):
        out[m.group(1)]={
            'route_code':int(m.group(2)),'schema_rev':int(m.group(3)),'id_policy':m.group(4),'replay_scope':m.group(5),'stamp_required':m.group(6)=='true','ordinal_required':m.group(7)=='true','mode_flag':int(m.group(8)),'phase_value':int(m.group(9)),'branch':m.group(10),'band_min':int(m.group(11)),'band_max':int(m.group(12))}
    return out

checks=[
    ('Q1', parse_q1_truth(), parse_source(root/'q01-long-context-protocol/src/range_validator.cpp')),
    ('Q2', parse_q2_truth(), parse_source(root/'q02-protocol-adaptation/src/protocol_adapter.cpp')),
]
for label,truth,code in checks:
    assert set(truth)==set(code)==set(targets)
    mism=[]
    for t in targets:
        if truth[t]"'!=code[t]:
            mism.append((t, truth[t], code[t]))
    print(label, '"'mismatches', len(mism))
    if mism:
        for item in mism[:5]:
            print(item)
            sys.exit(1)
