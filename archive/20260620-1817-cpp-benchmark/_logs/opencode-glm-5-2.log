import re
lines=open('v6.proto',encoding='utf-8').read().split('\n')
ac_lines=[i for i,l in enumerate(lines) if '适配契约' in l]
out=[]
for ac in ac_lines:
    # find message name: search backwards from ac for 'message X {'
    name=None
    for j in range(ac, max(ac-12,0), -1):
        m=re.match(r'message (\w+) \{', lines[j])
        if m: name=m.group(1); break
    out.append((ac+1, name))
# print only those whose name is one of the 48 bound ids
bound=set('stage_state stage_states stage_state_view stage_state_patch stage_state_legacy stage_state_v2 thrust_report thrust_reports thrust_report_view thrust_report_patch thrust_report_legacy thrust_report_v2 nav_solution nav_solutions nav_solution_view nav_solution_patch nav_solution_legacy nav_solution_v2 sep_event sep_events sep_event_view sep_event_patch sep_event_legacy sep_event_v2 fts_status fts_statuses fts_status_view fts_status_patch fts_status_legacy fts_status_v2 payload_frame payload_frames payload_frame_view payload_frame_patch payload_frame_legacy payload_frame_v2 link_quality link_qualities link_quality_view link_quality_patch link_quality_legacy link_quality_v2 thermal_sample thermal_samples thermal_sample_view thermal_sample_patch thermal_sample_legacy thermal_sample_v2'.split())
for ln,name in out:
    flag='BOUND' if name in bound else 'decoy'
    print(f'{ln:5d} {flag:6s} {name}')
