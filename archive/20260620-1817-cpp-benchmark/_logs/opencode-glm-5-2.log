import re
lines=open('v6.proto',encoding='utf-8').read().split('\n')
ac_lines=[i for i,l in enumerate(lines) if '适配契约' in l]
bound=['stage_state','stage_states','stage_state_view','stage_state_patch','stage_state_legacy','stage_state_v2','thrust_report','thrust_reports','thrust_report_view','thrust_report_patch','thrust_report_legacy','thrust_report_v2','nav_solution','nav_solutions','nav_solution_view','nav_solution_patch','nav_solution_legacy','nav_solution_v2','sep_event','sep_events','sep_event_view','sep_event_patch','sep_event_legacy','sep_event_v2','fts_status','fts_statuses','fts_status_view','fts_status_patch','fts_status_legacy','fts_status_v2','payload_frame','payload_frames','payload_frame_view','payload_frame_patch','payload_frame_legacy','payload_frame_v2','link_quality','link_qualities','link_quality_view','link_quality_patch','link_quality_legacy','link_quality_v2','thermal_sample','thermal_samples','thermal_sample_view','thermal_sample_patch','thermal_sample_legacy','thermal_sample_v2']
def getname(ac):
    for j in range(ac,max(ac-12,0),-1):
        m=re.match(r'message (\w+) \{',lines[j])
        if m: return m.group(1)
blocks={}
for ac in ac_lines:
    nm=getname(ac)
    if nm in bound:
        # collect contract lines from ac to ac+13
        txt='\n'.join(lines[ac:ac+14])
        blocks[nm]=txt
# parse fields
def parse(txt):
    f={}
    f['route_code']=re.search(r'route_code:\s*([^\n]*)',txt)
    f['schema_rev']=re.search(r'schema_rev:\s*([^\n]*)',txt)
    f['id_policy']=re.search(r'id_policy:\s*([^\n]*)',txt)
    f['replay_scope']=re.search(r'replay_scope:\s*([^\n]*)',txt)
    f['stamp_required']=re.search(r'stamp_required:\s*([^\n]*)',txt)
    f['ordinal_required']=re.search(r'ordinal_required:\s*([^\n]*)',txt)
    f['branch']=re.search(r'branch:\s*([^\n]*)',txt)
    f['band']=re.search(r'band:\s*([^\n]*)',txt)
    # mode_flag: take the LAST occurrence (renumber second line) -> decimal
    mfs=re.findall(r'mode_flag:\s*(\d+)\s*\(',txt)
    f['mode_flag']=mfs[-1] if mfs else (re.search(r'mode_flag:\s*(\d+)',txt) and re.search(r'mode_flag:\s*(\d+)',txt).group(1))
    pvs=re.findall(r'phase_value:\s*(\d+)',txt)
    f['phase_value']=pvs[-1] if pvs else None
    return {k:(v.group(1).strip() if hasattr(v,'group') else v) for k,v in f.items()}
for nm in bound:
    print('====',nm)
    print(parse(blocks[nm]))
