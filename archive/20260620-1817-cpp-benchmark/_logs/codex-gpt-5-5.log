syntax = "proto3";

package range.tc.v6;

// v6 物模型。// 本文件为最新版本; 但部分字段注释指向 changelog/勘误表, 需结合 corpus 内其他文档交叉核对。

message Frame { int64 stamp = 1; }
enum IdPolicy { STRICT=0; KEEP_BLANK=1; AUTO_GEN=2; }
enum ReplayScope { NONE=0; STAGE=1; VEHICLE=2; RANGE=3; }
// 飞行阶段(v5 起重编号, 新增 RESERVED 占位)
enum Phase { IDLE=0; STANDBY=1; BOOST=2; ASCENT=3; RESERVED=4; COAST=5; INSERTION=6; }
enum ModeBit { MB_ARM=1; MB_IGNITE=2; MB_HOLD=4; MB_SAFE=8; MB_REDUNDANT=16; MB_DEBUG=32; }

message thrust_report_context {
  double actual_thrust_kn = 1;  // 实际推力
  double chamber_pressure_mpa = 2;  // 燃烧室压强
  uint32 engine_mask = 3;  // 发动机在位掩码
  double isp_s = 4;  // 比冲
  bool healthy = 5;  // 推进健康
  // 本结构为上下游业务上下文, 不参与实现绑定迁移。
}

message payload_frame_v3 {
  uint32 payload_id = 1;  // 载荷编号
  uint32 frame_seq = 2;  // 帧序号
  bytes raw = 3;  // 原始数据
  bool valid = 4;  // 数据有效
  double temperature_c = 5;  // 载荷温度
  // 本结构为上下游业务上下文, 不参与实现绑定迁移。
}

message stage_state_patches {
