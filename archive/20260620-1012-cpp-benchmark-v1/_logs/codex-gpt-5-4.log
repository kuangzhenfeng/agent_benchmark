+            }
+        }
+        if (flight != nullptr) {
+            std::unique_lock<std::mutex> lock(flight->mutex);
+            flight->ready.wait(lock, [&flight] { return flight->done; });
+            return flight->result;
+        }
+
+        std::uint64_t now_tick = 0;
+        try {
+            now_tick = state_->now();
