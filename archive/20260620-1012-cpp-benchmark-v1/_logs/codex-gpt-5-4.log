+                ++loads;
+                return LoadResult::ok("v");
+            });
+        });
+        std::thread t2([&] {
+            second = cache.get_or_load("ttl0", 0, [&](const std::string&) {
+                ++loads;
+                return LoadResult::ok("unexpected");
+            });
+        });
+        t1.join();
+        t2.join();
+
+        assert(loads == 1);
+        assert(first.status == LoadStatus::ok);
+        assert(second.status == LoadStatus::ok);
+        assert(cache.size() == 0);
+    }
+}

