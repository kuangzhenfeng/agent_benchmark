diff --git a/archive/20260620-1012-cpp-benchmark-v1/agents/codex-gpt-5-4/q01-subscription-hub/tests/reentrancy_batch_checks.cpp b/archive/20260620-1012-cpp-benchmark-v1/agents/codex-gpt-5-4/q01-subscription-hub/tests/reentrancy_batch_checks.cpp
