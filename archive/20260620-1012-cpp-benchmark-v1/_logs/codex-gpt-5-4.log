     explicit State(std::size_t capacity, Clock now)
         : capacity(capacity), now(std::move(now)) {}
 
+    void touch_ready(std::unordered_map<std::string, ReadyEntry>::iterator it) {
+        lru.erase(it->second.lru_position);
