        content = f.read()
    
    # 查找所有message块
    i = 0
    while i < len(content):
        match = re.search(r'message\s+(\w+)\s*\{', content[i:])
        if not match:
            break
        msg_name = match.group(1)
        start = i + match.end()
        
        # 找到匹配的}
        brace_count = 1
        j = start
        while j < len(content) and brace_count > 0:
            if content[j] == '{':
                brace_count += 1
            elif content[j] == '}':
                brace_count -= 1
            j += 1
        
        msg_body = content[start:j-1]
        
        if '实现绑定: 是' in msg_body:
            meta = {}
            
            m = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
            if m: meta['route_code'] = int(m.group(1))
            
            m = re.search(r'小版本\s+schema_rev\s*=\s*(\d+)', msg_body)
            if m: meta['schema_rev'] = int(m.group(1))
            
            m = re.search(r'标识策略\s+id_policy\s*=\s*(\S+)', msg_body)
            if m: meta['id_policy'] = m.group(1)
            
            m = re.search(r'回放域\s+replay_scope\s*=\s*(\S+)', msg_body)
            if m: meta['replay_scope'] = m.group(1)
            
            m = re.search(r'需要时间戳\s+stamp_required\s*=\s*(\w+)', msg_body)
            if m: meta['stamp_required'] = m.group(1) == 'true'
            
            m = re.search(r'需要序号\s+ordinal_required\s*=\s*(\w+)', msg_body)
            if m: meta['ordinal_required'] = m.group(1) == 'true'
            
            m = re.search(r'模式位\s+mode_flag\s*=\s*(\d+)', msg_body)
            if m: meta['mode_flag'] = int(m.group(1))
            
            m = re.search(r'飞行阶段\s+phase\s*=\s*([^\n]+)', msg_body)
            if m: 
                phase_str = m.group(1).strip()
                if '=' in phase_str:
                    meta['phase_value'] = int(phase_str.split('=')[1])
                else:
                    meta['phase_value'] = int(phase_str)
            
            m = re.search(r'载荷分支\s+branch\s*=\s*(\S+)', msg_body)
            if m: meta['branch'] = m.group(1)
            
            m = re.search(r'合法区间\s+band\s*=\s*\[(\d+),\s*(\d+)\]', msg_body)
            if m:
                meta['band_min'] = int(m.group(1))
                meta['band_max'] = int(m.group(2))
            
            all_bindings[msg_name] = meta
        
        i = j

print(f"Found {len(all_bindings)} binding structures")
for name, meta in sorted(all_bindings.items()):
    print(f"{name}: {meta}")
