import re
import os

proto_dir = '/home/steven/app/agent_benchmark/benchmark/20260620-1936-cpp-benchmark-v2/agents/opencode-coding-kimi/q02-protocol-adaptation/系统B'
all_bindings = {}

for filename in ['definitions.proto', 'status.proto', 'action.proto', 'config.proto', 'event.proto']:
    filepath = os.path.join(proto_dir, filename)
    with open(filepath, 'r') as f:
        content = f.read()
    
    # 找到所有"是否实现绑定: 是"的位置
    for m in re.finditer(r'是否实现绑定: 是', content):
        idx = m.start()
        # 向前查找message定义
        before = content[:idx]
        lines = before.split('\n')
        msg_name = None
        for i in range(len(lines)-1, -1, -1):
            line = lines[i].strip()
            if line.startswith('message '):
                msg_name = line.split()[1].rstrip('{').strip()
                break
        
        if not msg_name:
            continue
            
        # 提取该结构后的元数据（在message块内）
        # 找到message开始的{位置
        msg_start = before.rfind('message ' + msg_name)
        if msg_start < 0:
            continue
        
        # 找到message块的结束
        brace_start = content.find('{', msg_start)
        brace_count = 1
        j = brace_start + 1
        while j < len(content) and brace_count > 0:
            if content[j] == '{':
                brace_count += 1
            elif content[j] == '}':
                brace_count -= 1
            j += 1
        
        msg_body = content[brace_start+1:j-1]
        
        meta = {}
        
        m_rc = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
        if m_rc: meta['route_code'] = int(m_rc.group(1))
        
        m_sr = re.search(r'小版本\s+schema_rev\s*=\s*(\d+)', msg_body)
        if m_sr: meta['schema_rev'] = int(m_sr.group(1))
        
        m_ip = re.search(r'标识策略\s+id_policy\s*=\s*(\S+)', msg_body)
        if m_ip: meta['id_policy'] = m_ip.group(1)
        
        m_rs = re.search(r'回放域\s+replay_scope\s*=\s*(\S+)', msg_body)
        if m_rs: meta['replay_scope'] = m_rs.group(1)
        
        m_st = re.search(r'需要时间戳\s+stamp_required\s*=\s*(\w+)', msg_body)
        if m_st: meta['stamp_required'] = m_st.group(1) == 'true'
        
        m_or = re.search(r'需要序号\s+ordinal_required\s*=\s*(\w+)', msg_body)
        if m_or: meta['ordinal_required'] = m_or.group(1) == 'true'
        
        m_mf = re.search(r'模式位\s+mode_flag\s*=\s*(\d+)', msg_body)
        if m_mf: meta['mode_flag'] = int(m_mf.group(1))
        
        m_ph = re.search(r'飞行阶段\s+phase\s*=\s*([^\n]+)', msg_body)
        if m_ph: 
            phase_str = m_ph.group(1).strip()
            if '=' in phase_str:
                meta['phase_value'] = int(phase_str.split('=')[1])
            else:
                meta['phase_value'] = int(phase_str)
        
        m_br = re.search(r'载荷分支\s+branch\s*=\s*(\S+)', msg_body)
        if m_br: meta['branch'] = m_br.group(1)
        
        m_ba = re.search(r'合法区间\s+band\s*=\s*\[(\d+),\s*(\d+)\]', msg_body)
        if m_ba:
            meta['band_min'] = int(m_ba.group(1))
            meta['band_max'] = int(m_ba.group(2))
        
        all_bindings[msg_name] = meta

print(f"Found {len(all_bindings)} binding structures")
for name, meta in sorted(all_bindings.items()):
    print(f"{name}: {meta}")
