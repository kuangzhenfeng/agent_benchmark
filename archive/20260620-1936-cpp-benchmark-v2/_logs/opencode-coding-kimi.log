import re
filepath = '/home/steven/app/agent_benchmark/benchmark/20260620-1936-cpp-benchmark-v2/agents/opencode-coding-kimi/q02-protocol-adaptation/系统B/status.proto'
with open(filepath, 'r') as f:
    content = f.read()

# 找到所有"是否实现绑定: 是"的位置
for m in re.finditer(r'是否实现绑定: 是', content):
    idx = m.start()
    # 向前查找结构代号
    before = content[:idx]
    lines = before.split('\n')
    msg_name = None
    for i in range(len(lines)-1, -1, -1):
        line = lines[i].strip()
        if line.startswith('// 结构代号:'):
            msg_name = line.split(':')[1].strip().rstrip('.')
            break
    
    if msg_name:
        # 向后查找该结构的元数据 - 在message块内
        after = content[idx:]
        # 找到message定义
        msg_match = re.search(r'message\s+' + msg_name + r'\s*\{', after)
        if msg_match:
            # 提取message块内容
            start = idx + msg_match.end()
            brace_count = 1
            j = start
            while j < len(content) and brace_count > 0:
                if content[j] == '{':
                    brace_count += 1
                elif content[j] == '}':
                    brace_count -= 1
                j += 1
            
            msg_body = content[start:j-1]
            
            # 提取关键信息
            m_rc = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
            if m_rc:
                print(f'{msg_name}: route_code={m_rc.group(1)}')
            else:
                print(f'{msg_name}: NO route_code')
