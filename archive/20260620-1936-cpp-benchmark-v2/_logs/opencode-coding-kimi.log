\n        vals = results.get(s, {})\n        band = vals.get(\"band\", [\"\", \"\"])\n        if isinstance(band, list) and len(band) == 2:\n            band_min, band_max = band\n        else:\n            band_min, band_max = \"\", \"\"\n        \n        row = [\n            family_name,\n            s,\n            str(vals.get(\"route_code\", \"\")),\n            str(vals.get(\"schema_rev\", \"\")),\n            vals.get(\"id_policy\", \"\"),\n            vals.get(\"replay_scope\", \"\"),\n            str(vals.get(\"stamp_required\", \"\")).lower(),\n            str(vals.get(\"ordinal_required\", \"\")).lower(),\n            str(vals.get(\"mode_flag\", \"\")),\n            str(vals.get(\"phase_value\", \"\")),\n            vals.get(\"branch\", \"\"),\n            str(band_min),\n            str(band_max),\n        ]\n        print(\"| \" + \" | \".join(row) + \" |\")\n\nprint(\"\\n---\\n\")\n\n# Also generate a compact CSV-like format\nprint(\"## Compact Format\\n\")\nfor family_name, structs in families:\n    print(f\"\\n### {family_name}\")\n    for s in structs:\n        vals = results.get(s, {})\n        band = vals.get(\"band\", [\"\", \"\"])\n        if isinstance(band, list) and len(band) == 2:\n            band_min, band_max = band\n        else:\n            band_min, band_max = \"\", \"\"\n        \n        print(f\"  {s}: rc={vals.get('route_code','')}, sr={vals.get('schema_rev','')}, ip={vals.get('id_policy','')}, \"\n              f\"rs={vals.get('replay_scope','')}, st={str(vals.get('stamp_required','')).lower()}, \"\n              f\"ord={str(vals.get('ordinal_required','')).lower()}, mf=0x{vals.get('mode_flag',0):X}, \"\n              f\"pv={vals.get('phase_value','')}, br={vals.get('branch','')}, \"\n              f\"band=[{band_min},{band_max}]\")\n\nPYEOF" action.permission=* action.action=allow action.pattern=*
