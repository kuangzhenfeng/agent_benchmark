import re
import os
import glob

# 映射表
id_policy_map = {
    '严格必填': 'IdPolicy::strict',
    '保留空': 'IdPolicy::keep_blank',
    '保留空值': 'IdPolicy::keep_blank',
    '空则生成': 'IdPolicy::auto_gen',
}

replay_map = {
    '不回放': 'ReplayScope::none',
    '本级': 'ReplayScope::stage',
    '本箭': 'ReplayScope::vehicle',
    '本靶区': 'ReplayScope::range',
}

branch_map = {
    '遥测': 'Branch::telemetry',
    '指令': 'Branch::command',
    '配置': 'Branch::config',
    '事件': 'Branch::event',
}

def parse_phase(phase_str):
    if '=' in phase_str:
        return int(phase_str.split('=')[1])
    return int(phase_str)

proto_dir = '/home/steven/app/agent_benchmark/benchmark/20260620-1936-cpp-benchmark-v2/agents/opencode-coding-kimi/q02-protocol-adaptation/系统B'
all_bindings = {}

for filename in ['definitions.proto', 'status.proto', 'action.proto', 'config.proto', 'event.proto']:
    filepath = os.path.join(proto_dir, filename)
    with open(filepath, 'r') as f:
        content = f.read()
    
    # 查找所有message块 - 使用更精确的模式
    # message name { ... }
    i = 0
    while i < len(content):
        match = re.search(r'message\s+(\w+)\s*\{', content[i:])
        if not match:
            break
        msg_name = match.group(1)
        start = i + match.end()
        
        # 找到匹配的}
        brace_count = 1
        j = start
        while j < len(content) and brace_count > 0:
            if content[j] == '{':
                brace_count += 1
            elif content[j] == '}':
                brace_count -= 1
            j += 1
        
        msg_body = content[start:j-1]
        
        if '是否实现绑定: 是' in msg_body:
            meta = {}
            
            m = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
            if m: meta['route_code'] = int(m.group(1))
            
            m = re.search(r'小版本\s+schema_rev\s*=\s*(\d+)', msg_body)
            if m: meta['schema_rev'] = int(m.group(1))
            
            m = re.search(r'标识策略\s+id_policy\s*=\s*(\S+)', msg_body)
            if m: meta['id_policy'] = m.group(1)
            
            m = re.search(r'回放域\s+replay_scope\s*=\s*(\S+)', msg_body)
            if m: meta['replay_scope'] = m.group(1)
            
            m = re.search(r'需要时间戳\s+stamp_required\s*=\s*(\w+)', msg_body)
            if m: meta['stamp_required'] = m.group(1) == 'true'
            
            m = re.search(r'需要序号\s+ordinal_required\s*=\s*(\w+)', msg_body)
            if m: meta['ordinal_required'] = m.group(1) == 'true'
            
            m = re.search(r'模式位\s+mode_flag\s*=\s*(\d+)', msg_body)
            if m: meta['mode_flag'] = int(m.group(1))
            
            m = re.search(r'飞行阶段\s+phase\s*=\s*([^\n]+)', msg_body)
            if m: meta['phase_value'] = parse_phase(m.group(1).strip())
            
            m = re.search(r'载荷分支\s+branch\s*=\s*(\S+)', msg_body)
            if m: meta['branch'] = m.group(1)
            
            m = re.search(r'合法区间\s+band\s*=\s*\[(\d+),\s*(\d+)\]', msg_body)
            if m:
                meta['band_min'] = int(m.group(1))
                meta['band_max'] = int(m.group(2))
            
