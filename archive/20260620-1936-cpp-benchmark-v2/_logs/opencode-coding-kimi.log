import re
import os
import glob

# 映射表
id_policy_map = {
    '严格必填': 'IdPolicy::strict',
    '保留空': 'IdPolicy::keep_blank',
    '保留空值': 'IdPolicy::keep_blank',
    '空则生成': 'IdPolicy::auto_gen',
}

replay_map = {
    '不回放': 'ReplayScope::none',
    '本级': 'ReplayScope::stage',
    '本箭': 'ReplayScope::vehicle',
    '本靶区': 'ReplayScope::range',
}

branch_map = {
    '遥测': 'Branch::telemetry',
    '指令': 'Branch::command',
    '配置': 'Branch::config',
    '事件': 'Branch::event',
}

phase_map = {
    'idle=0': 0,
    'ready=1': 1,
    'boost=2': 2,
    'ascent=3': 3,
    'coast=4': 4,
    'insertion=5': 5,
}

def parse_phase(phase_str):
    # 处理 "phase = boost=2" 或 "phase = 2"
    if '=' in phase_str:
        return int(phase_str.split('=')[1])
    return int(phase_str)

def extract_bindings(proto_dir):
    bindings = {}
    for proto_file in glob.glob(os.path.join(proto_dir, '*.proto')):
        with open(proto_file, 'r') as f:
            content = f.read()
        
        # 查找所有实现绑定的结构
        # 模式: 结构代号: xxx 后面跟着适配契约元数据
        messages = re.findall(r'message\s+(\w+)\s*\{([^}]+)\}', content, re.DOTALL)
        for msg_name, msg_body in messages:
            if '是否实现绑定: 是' in msg_body:
                # 提取元数据
                meta = {}
                
                # route_code
                m = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
                if m:
                    meta['route_code'] = int(m.group(1))
                
                # schema_rev
                m = re.search(r'小版本\s+schema_rev\s*=\s*(\d+)', msg_body)
                if m:
                    meta['schema_rev'] = int(m.group(1))
                
                # id_policy
                m = re.search(r'标识策略\s+id_policy\s*=\s*(\S+)', msg_body)
                if m:
                    meta['id_policy'] = m.group(1)
                
                # replay_scope
                m = re.search(r'回放域\s+replay_scope\s*=\s*(\S+)', msg_body)
                if m:
                    meta['replay_scope'] = m.group(1)
                
                # stamp_required
                m = re.search(r'需要时间戳\s+stamp_required\s*=\s*(\w+)', msg_body)
                if m:
                    meta['stamp_required'] = m.group(1) == 'true'
                
                # ordinal_required
                m = re.search(r'需要序号\s+ordinal_required\s*=\s*(\w+)', msg_body)
                if m:
                    meta['ordinal_required'] = m.group(1) == 'true'
                
                # mode_flag
                m = re.search(r'模式位\s+mode_flag\s*=\s*(\d+)', msg_body)
                if m:
                    meta['mode_flag'] = int(m.group(1))
                
                # phase
                m = re.search(r'飞行阶段\s+phase\s*=\s*([^\n]+)', msg_body)
                if m:
                    meta['phase_value'] = parse_phase(m.group(1).strip())
                
                # branch
                m = re.search(r'载荷分支\s+branch\s*=\s*(\S+)', msg_body)
                if m:
                    meta['branch'] = m.group(1)
                
                # band
                m = re.search(r'合法区间\s+band\s*=\s*\[(\d+),\s*(\d+)\]', msg_body)
                if m:
                    meta['band_min'] = int(m.group(1))
                    meta['band_max'] = int(m.group(2))
                
                bindings[msg_name] = meta
    
    return bindings

# 提取所有proto文件中的绑定结构
all_bindings = {}
for filename in ['definitions.proto', 'status.proto', 'action.proto', 'config.proto', 'event.proto']:
    filepath = os.path.join('/home/steven/app/agent_benchmark/benchmark/20260620-1936-cpp-benchmark-v2/agents/opencode-coding-kimi/q02-protocol-adaptation/系统B', filename)
    if os.path.exists(filepath):
        with open(filepath, 'r') as f:
            content = f.read()
        
        # 查找所有message
        messages = re.findall(r'message\s+(\w+)\s*\{([^}]*(?:\{[^}]*\}[^}]*)*)\}', content, re.DOTALL)
        for msg_name, msg_body in messages:
            if '是否实现绑定: 是' in msg_body:
                meta = {}
                
                # route_code
                m = re.search(r'路由码\s+route_code\s*=\s*(\d+)', msg_body)
                if m:
                    meta['route_code'] = int(m.group(1))
                
                # schema_rev
                m = re.search(r'小版本\s+schema_rev\s*=\s*(\d+)', msg_body)
                if m:
                    meta['schema_rev'] = int(m.group(1))
                
                # id_policy
                m = re.search(r'标识策略\s+id_policy\s*=\s*(\S+)', msg_body)
                if m:
                    meta['id_policy'] = m.group(1)
                
                # replay_scope
                m = re.search(r'回放域\s+replay_scope\s*=\s*(\S+)', msg_body)
                if m:
                    meta['replay_scope'] = m.group(1)
                
                # stamp_required
                m = re.search(r'需要时间戳\s+stamp_required\s*=\s*(\w+)', msg_body)
                if m:
                    meta['stamp_required'] = m.group(1) == 'true'
                
                # ordinal_required
                m = re.search(r'需要序号\s+ordinal_required\s*=\s*(\w+)', msg_body)
                if m:
                    meta['ordinal_required'] = m.group(1) == 'true'
                
                # mode_flag
                m = re.search(r'模式位\s+mode_flag\s*=\s*(\d+)', msg_body)
                if m:
                    meta['mode_flag'] = int(m.group(1))
                
                # phase
                m = re.search(r'飞行阶段\s+phase\s*=\s*([^\n]+)', msg_body)
                if m:
                    meta['phase_value'] = parse_phase(m.group(1).strip())
                
                # branch
                m = re.search(r'载荷分支\s+branch\s*=\s*(\S+)', msg_body)
                if m:
                    meta['branch'] = m.group(1)
                
                # band
                m = re.search(r'合法区间\s+band\s*=\s*\[(\d+),\s*(\d+)\]', msg_body)
                if m:
                    meta['band_min'] = int(m.group(1))
                    meta['band_max'] = int(m.group(2))
                
                all_bindings[msg_name] = meta

print(f"Found {len(all_bindings)} binding structures")
for name, meta in sorted(all_bindings.items()):
    print(f"{name}: {meta}")
