import re
filepath = '/home/steven/app/agent_benchmark/benchmark/20260620-1936-cpp-benchmark-v2/agents/opencode-coding-kimi/q02-protocol-adaptation/系统B/status.proto'
with open(filepath, 'r') as f:
    content = f.read()

# 手动解析 - 找到所有message块
pos = 0
bindings = []
while True:
    match = re.search(r'message\s+((\w+))\s*\{', content[pos:])
    if not match:
        break
    msg_name = match.group(1)
    start = pos + match.end()
    
    # 找到匹配的}
    brace_count = 1
    j = start
    while j < len(content) and brace_count > 0:
        if content[j] == '{':
            brace_count += 1
        elif content[j] == '}':
            brace_count -= 1
        j += 1
    
    msg_body = content[start:j-1]
    
    if '实现绑定: 是' in msg_body:
        bindings.append(msg_name)
        print(f'Found binding: {msg_name}')
    
    pos = j

print(f'Total bindings: {len(bindings)}')
