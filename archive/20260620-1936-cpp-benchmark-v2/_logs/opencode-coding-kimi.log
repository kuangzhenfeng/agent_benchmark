) for f in all_fields]) + \"|\"\nprint(sep)\n\nfor family_name, structs in families:\n    for s in structs:\n        vals = results.get(s, {})\n        band = vals.get(\"band\", [\"\", \"\"])\n        if isinstance(band, list) and len(band) == 2:\n            band_min, band_max = band\n        else:\n            band_min, band_max = \"\", \"\"\n        \n        # mode_flag as hex\n        mf = vals.get(\"mode_flag\", \"\")\n        if mf != \"\":\n            mf_hex = f\"0x{int(mf):X}\"\n        else:\n            mf_hex = \"\"\n        \n        row = [\n            family_name,\n            s,\n            str(vals.get(\"route_code\", \"\")),\n            str(vals.get(\"schema_rev\", \"\")),\n            vals.get(\"id_policy\", \"\"),\n            vals.get(\"replay_scope\", \"\"),\n            str(vals.get(\"stamp_required\", \"\")).lower(),\n            str(vals.get(\"ordinal_required\", \"\")).lower(),\n            mf_hex,\n            str(vals.get(\"phase_value\", \"\")),\n            vals.get(\"branch\", \"\"),\n            str(band_min),\n            str(band_max),\n        ]\n        print(\"| \" + \" | \".join(row) + \" |\")\n\nprint(\"\\n\")\n\n# Summary by family\nprint(\"## Summary by Family\\n\")\nfor family_name, structs in families:\n    print(f\"\\n### {family_name}\")\n    for s in structs:\n        vals = results.get(s, {})\n        band = vals.get(\"band\", [\"\", \"\"])\n        if isinstance(band, list) and len(band) == 2:\n            band_str = f\"[{band[0]},{band[1]}]\"\n        else:\n            band_str = \"\"\n        mf = vals.get(\"mode_flag\", \"\")\n        mf_hex = f\"0x{int(mf):X}\" if mf != \"\" else \"\"\n        print(f\"  {s}: rc={vals.get('route_code','')}, sr={vals.get('schema_rev','')}, \"\n              f\"ip={vals.get('id_policy','')}, rs={vals.get('replay_scope','')}, \"\n              f\"st={str(vals.get('stamp_required','')).lower()}, \"\n              f\"ord={str(vals.get('ordinal_required','')).lower()}, \"\n              f\"mf={mf_hex}, pv={vals.get('phase_value','')}, \"\n              f\"br={vals.get('branch','')}, band={band_str}\")\n\nPYEOF" action.permission=* action.action=allow action.pattern=*
